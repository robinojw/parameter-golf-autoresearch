# Required
GITHUB_TOKEN=ghp_...            # for PR/commit fetching
RUNPOD_API_KEY=...              # for compute layer
RUNPOD_TEMPLATE_ID=y5cejece4j   # parameter-golf official RunPod template

# Compute budget
TOTAL_COMPUTE_CREDITS=500.00    # your starting credit balance
RUNPOD_MIN_RESERVE=50.00        # halt Tier 2 submissions below this

# Grading harness (auto-detects by default)
GRADING_HARNESS=auto            # auto | opencode | claude

# Optional
S2_API_KEY=...                  # Semantic Scholar (raises rate limit)
SINCE_HOURS=48                  # lookback window for new research
LOCAL_PROMOTION_THRESHOLD=0.97  # local bpb must be < baseline * this to promote
LOCAL_BASELINE=                  # set after first MLX baseline run
PROMOTION_FALLBACK_WINDOW=10    # consecutive local runs before adaptive threshold relaxation

# Tavily web search
TAVILY_API_KEY=tvly-...         # for Tavily search + extract
TAVILY_MONTHLY_BUDGET_USD=5.00  # soft cap on Tavily spend
TAVILY_HOURLY_BREAKING_NEWS=true # toggle the 1-hour news checker

# Dashboard (optional — omit to disable push)
DASHBOARD_URL=                  # e.g. https://your-dashboard.workers.dev
DASHBOARD_TOKEN=                # bearer token matching the Worker's secret
